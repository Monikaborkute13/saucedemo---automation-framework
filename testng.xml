<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<suite name="AutomationSuite" parallel="false">

    <listeners>
        <listener class-name="utilities.TestListener"/>
    </listeners>

    <test name="AllTests">

        <classes>
            <class name="testcases.LoginTest"/>
            <class name="testcases.LogoutTest"/>
            <class name="testcases.CheckoutTest"/>
            <class name="testcases.NavigationTest"/>
            <class name="testcases.UITest"/>
            <class name="testcases.SecurityTest"/>
            <class name="testcases.PerformanceTest"/>
            <class name="testcases.EdgeCaseTest"/>
        </classes>

    </test>

</suite>
